PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/onboarding?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
OPENAI_API_KEY=replace_if_used
MAIL_ENABLED=false

# Preferred: Gmail SMTP via App Password
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password
EMAIL_FROM=Onboard <youraddress@gmail.com>

# Optional generic SMTP alternative
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password

FRONTEND_URL=https://your-frontend-domain.com